# VITE_API_BASE sets both the domain and path prefix for API/WebSocket calls
# (build time):
#   unset/empty                        -> same origin, same mount prefix as the
#                                         page (production default; the backend
#                                         injects the prefix via <base href>)
#   /quant-arena                       -> /quant-arena/api/...
#   http://127.0.0.1:18792/quant-arena -> http://127.0.0.1:18792/quant-arena/api/...
#
# Production builds need no env vars. For local frontend dev against the
# default local backend:
VITE_API_BASE=http://127.0.0.1:18792
