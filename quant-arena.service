# vim: ft=systemd
[Unit]
Description=Create quant-arena tmux session
After=default.target

[Service]
Type=oneshot
WorkingDirectory=%h/quant-arena
ExecStartPre=/bin/bash -c 'cd frontend && pnpm build'
ExecStartPre=/bin/bash -c 'while ! echo > /dev/tcp/127.0.0.1/7890; do sleep 1; done'
ExecStart=/usr/bin/tmuxp load -d .
RemainAfterExit=yes

[Install]
WantedBy=default.target
